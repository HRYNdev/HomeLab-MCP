# HomeLab MCP — пример конфигурации
# Скопируй в .env и заполни своими данными
# Или запусти: python3.13 setup.py

# ── Home Assistant ────────────────────────────────────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# ── Роутер: OpenWRT (SSH) ─────────────────────────────────────────────────────
OPENWRT_HOST=192.168.1.1
OPENWRT_PORT=22
OPENWRT_USER=root
OPENWRT_PASSWORD=your_router_password

# ── Роутер: OPNsense (REST API) ───────────────────────────────────────────────
# System → Access → Users → ваш юзер → API keys → +
OPNSENSE_HOST=192.168.1.1
OPNSENSE_PORT=443
OPNSENSE_KEY=your_api_key
OPNSENSE_SECRET=your_api_secret
OPNSENSE_VERIFY_SSL=false

# ── Роутер: MikroTik (REST API, RouterOS 7.1+) ───────────────────────────────
MIKROTIK_HOST=192.168.1.1
MIKROTIK_PORT=443
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your_password
MIKROTIK_VERIFY_SSL=false

# ── Linux сервер / Raspberry Pi (SSH) ────────────────────────────────────────
PI_HOST=192.168.1.100
PI_PORT=22
PI_USER=pi
PI_PASSWORD=your_pi_password
# Или SSH ключ (рекомендуется):
# PI_KEY_PATH=/home/user/.ssh/id_rsa

# ── AdGuard Home ──────────────────────────────────────────────────────────────
ADGUARD_URL=http://192.168.1.1:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=your_password

# ── Pi-hole v6+ ───────────────────────────────────────────────────────────────
PIHOLE_URL=http://pi.hole
PIHOLE_PASSWORD=your_web_password

# ── Uptime Kuma ───────────────────────────────────────────────────────────────
UPTIME_KUMA_URL=http://localhost:3001
UPTIME_KUMA_SLUG=default

# ── Proxmox VE ────────────────────────────────────────────────────────────────
# Токен: Datacenter → Permissions → API Tokens → Add
PROXMOX_HOST=192.168.1.10
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=root@pam!mytoken
PROXMOX_TOKEN_SECRET=your_token_secret
# Или логин/пароль:
# PROXMOX_PASSWORD=your_password
PROXMOX_VERIFY_SSL=false

# ── Portainer ─────────────────────────────────────────────────────────────────
# Токен: Account → Access tokens → Add access token
PORTAINER_URL=https://localhost:9443
PORTAINER_TOKEN=ptr_your_token_here
# Или логин/пароль:
# PORTAINER_USER=admin
# PORTAINER_PASSWORD=your_password
PORTAINER_VERIFY_SSL=false

# ── Grafana ───────────────────────────────────────────────────────────────────
# Токен: Administration → Service accounts → Add → Add token
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=your_service_account_token
# Или логин/пароль:
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=your_password

# ── TrueNAS SCALE/CORE ────────────────────────────────────────────────────────
# API Key: Top-right menu → API Keys → Add
TRUENAS_URL=http://192.168.1.10
TRUENAS_API_KEY=your_api_key
# Или логин/пароль:
# TRUENAS_USER=root
# TRUENAS_PASSWORD=your_password
TRUENAS_VERIFY_SSL=false

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# Ключ: Dashboard → API Keys → +
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=your_api_key_here

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_MODE=none
ADMIN_SECRET=change_this_to_something_secret
